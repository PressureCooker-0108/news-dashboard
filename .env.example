# ──────────────────────────────────────────────
# News Dashboard — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Backend ───────────────────────────────────

# Database URL
# For local development (SQLite): leave unset or comment out
# For production (PostgreSQL on Render):
#   DATABASE_URL=postgresql://user:password@host:5432/news_dashboard
# DATABASE_URL=

# Server Port (Render sets this automatically via $PORT)
# Default: 8001
# PORT=8001

# ── Frontend ──────────────────────────────────

# Backend API URL (required for frontend to connect)
# For local dev:   http://127.0.0.1:8001
# For production:  https://your-backend.onrender.com
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
