# ──────────────────────────────────────────────
# News Dashboard — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# For Docker:
#   docker compose up -d  # uses docker-compose.yml
#
# For Render:
#   Set these in the Render dashboard → Environment Variables.

# ── Backend ───────────────────────────────────

# Database URL
# ──────────────────────────────────────────────
# Local dev with Docker: leave unset (docker-compose sets DATABASE_URL automatically)
# Local dev without Docker (SQLite): leave unset — defaults to sqlite:///news.db
#
# Production with Supabase (recommended):
#   1. Create a free Supabase project at https://supabase.com
#   2. Go to Project Settings → Database → Connection string
#   3. Copy the "URI" connection string (NOT the psql one)
#   4. Replace "postgres://" with "postgresql://" if needed
#   5. Add &sslmode=require at the end
#   6. Paste it here:
#
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
#
# Production with Render PostgreSQL:
#   Set DATABASE_URL to the internal connection string Render provides.
#
# DATABASE_URL=

# Server Port (Render sets this via $PORT)
# Default: 8001
# PORT=8001

# API Key for auth on write endpoints (POST /pipeline/run, etc.)
# ──────────────────────────────────────────────
# If set, all POST endpoints require the X-API-Key header.
# If unset, all endpoints are open (safe for local dev, but lock down before
# deploying publicly).
# Generate one: openssl rand -hex 32
# API_KEY=

# CORS allowed origins
# ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In dev:  http://localhost:3000,http://127.0.0.1:3000
# In prod: https://your-frontend.vercel.app
# Default: * (allow all — change this for production!)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
# ──────────────────────────────────────────────
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_FORMAT: text (human-readable, default) or json (for Datadog/CloudWatch/Logstash)
# LOG_LEVEL=INFO
# LOG_FORMAT=text

# ── Frontend ──────────────────────────────────

# Backend API URL (required)
# For local dev:   http://127.0.0.1:8001
# For Docker:      http://localhost:8001
# For production:  https://your-backend.onrender.com
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
