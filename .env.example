# ──────────────────────────────────────────────
# News Dashboard — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Backend ───────────────────────────────────

# Database URL
# ──────────────────────────────────────────────
# Local development (SQLite): leave unset or comment out — it defaults to
# sqlite:///news.db automatically.
#
# Production on Render with Supabase (recommended):
#   1. Create a free Supabase project at https://supabase.com
#   2. Go to Project Settings → Database → Connection string
#   3. Copy the "URI" connection string (NOT the psql one)
#   4. Replace "postgres://" with "postgresql://" if needed
#   5. Add &sslmode=require at the end
#   6. Paste it here:
#
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
#
# ⚠️ If using Supabase's transaction pooler (port 6543) and seeing
#    SQLAlchemy errors about prepared statements, add this to your
#    engine connect_args in database.py:
#      "prepared_statement_cache_size": 0
#    The session pooler (port 5432, default) doesn't need this.
#
# Production on Render with Render PostgreSQL (alternative):
# Render provides this automatically. No manual setup needed.
# DATABASE_URL=

# Server Port (Render sets this automatically via $PORT)
# Default: 8001
# PORT=8001

# ── Frontend ──────────────────────────────────

# Backend API URL (required for frontend to connect)
# For local dev:   http://127.0.0.1:8001
# For production:  https://your-backend.onrender.com
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
